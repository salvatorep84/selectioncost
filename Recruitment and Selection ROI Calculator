      const costoTotaleConLinkedIn = costoOperativoTotaleConLinkedIn + values.costoSoluzioneLinkedIn;
      const costoMedioPerSelezioneConLinkedIn = costoTotaleConLinkedIn / values.numeroSelezioni;
      return { giorniTimeToHireLinkedIn, costoTimeToHireLinkedIn, feeSelezioneLinkedIn, premioCambioLinkedIn, nuovaRalStimataLinkedIn, costoSingolaSelezioneConLinkedIn, costoOperativoTotaleConLinkedIn, costoTotaleConLinkedIn, costoMedioPerSelezioneConLinkedIn };
    }

    function calculateBreakEven(solutionCost, savingPerHire, numberOfHires) {
      if (solutionCost === 0) return { breakEvenHires: 0, reached: true, unavailable: false, remainingHires: 0 };
      if (savingPerHire <= 0) return { breakEvenHires: null, reached: false, unavailable: true, remainingHires: null };
      const breakEvenHires = Math.max(0, Math.ceil(solutionCost / savingPerHire));
      const reached = numberOfHires >= breakEvenHires;
      return { breakEvenHires, reached, unavailable: false, remainingHires: reached ? 0 : breakEvenHires - numberOfHires };
    }

    function calculateRoi(netSaving, solutionCost) {
      if (solutionCost === 0) return { roi: null, applicable: false, benefitPerEuro: null };
      return { roi: (netSaving / solutionCost) * 100, applicable: true, benefitPerEuro: netSaving / solutionCost };
    }

    function calculateComparison(values, base, linkedIn) {
      const risparmioPerSelezione = base.costoSingolaSelezioneSenzaLinkedIn - linkedIn.costoSingolaSelezioneConLinkedIn;
      const risparmioOperativoTotale = risparmioPerSelezione * values.numeroSelezioni;
      const risparmioNetto = base.costoTotaleSenzaLinkedIn - linkedIn.costoTotaleConLinkedIn;
      const risparmioNettoPercentuale = base.costoTotaleSenzaLinkedIn > 0 ? (risparmioNetto / base.costoTotaleSenzaLinkedIn) * 100 : 0;
      const breakEven = calculateBreakEven(values.costoSoluzioneLinkedIn, risparmioPerSelezione, values.numeroSelezioni);
      const roi = calculateRoi(risparmioNetto, values.costoSoluzioneLinkedIn);
      return { risparmioPerSelezione, risparmioOperativoTotale, risparmioNetto, risparmioNettoPercentuale, breakEven, roi };
    }

    function setStatus(cardId, status) { const card = document.getElementById(cardId); card.classList.remove('positive','neutral','negative'); card.classList.add(status); }
    function clearResults() { Object.entries(el).forEach(([id, node]) => { if (!node) return; node.textContent = id.includes('formula') || id.includes('Message') ? translate('invalidSummary') : formatCurrency(0); }); ['netSavingCard','breakEvenCard','roiCard'].forEach((id) => setStatus(id, 'neutral')); }

    function updateBaseScenario(values, base) {
      el.costoTotaleSenzaLinkedIn.textContent = formatCurrency(base.costoTotaleSenzaLinkedIn); el.produttivitaGiornaliera.textContent = formatCurrency(base.produttivitaGiornaliera); el.costoTimeToHire.textContent = formatCurrency(base.costoTimeToHire); el.premioCambio.textContent = formatCurrency(base.premioCambio); el.nuovaRalStimata.textContent = formatCurrency(base.nuovaRalStimata); el.feeSelezione.textContent = formatCurrency(base.feeSelezione); el.costoSingolaSelezioneSenzaLinkedIn.textContent = formatCurrency(base.costoSingolaSelezioneSenzaLinkedIn); el.numeroSelezioniResult.textContent = values.numeroSelezioni;
      el.formulaSenzaLinkedIn.textContent = `${translate('feeLine',{value:formatCurrency(base.feeSelezione)})}\n+ ${translate('timeToHireLine',{value:formatCurrency(base.costoTimeToHire)})}\n+ ${translate('premiumLine',{value:formatCurrency(base.premioCambio)})}\n${translate('perHireLine',{value:formatCurrency(base.costoSingolaSelezioneSenzaLinkedIn)})}\n\n${translate('multiplyLine',{value:formatCurrency(base.costoSingolaSelezioneSenzaLinkedIn), count:values.numeroSelezioni})}\n${translate('totalWithoutLine',{value:formatCurrency(base.costoTotaleSenzaLinkedIn)})}`;
    }

    function updateLinkedInScenario(values, base, linkedIn) {
      el.costoTotaleConLinkedIn.textContent = formatCurrency(linkedIn.costoTotaleConLinkedIn); el.timeToHireIniziale.textContent = `${formatDays(values.giorniTimeToHire)} ${translate('daysSuffix')}`; el.riduzioneTimeToHireLinkedInResult.textContent = formatPercentage(values.riduzioneTimeToHireLinkedIn); el.giorniTimeToHireLinkedIn.textContent = `${formatDays(linkedIn.giorniTimeToHireLinkedIn)} ${translate('daysSuffix')}`; el.costoTimeToHireLinkedIn.textContent = formatCurrency(linkedIn.costoTimeToHireLinkedIn); el.premioCambioInizialeLinkedIn.textContent = formatCurrency(base.premioCambio); el.riduzionePremioLinkedInResult.textContent = formatPercentage(values.riduzionePremioLinkedIn); el.premioCambioLinkedIn.textContent = formatCurrency(linkedIn.premioCambioLinkedIn); el.nuovaRalStimataLinkedIn.textContent = formatCurrency(linkedIn.nuovaRalStimataLinkedIn); el.feeSelezioneLinkedIn.textContent = formatCurrency(linkedIn.feeSelezioneLinkedIn); el.costoSingolaSelezioneConLinkedIn.textContent = formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn); el.costoOperativoTotaleConLinkedIn.textContent = formatCurrency(linkedIn.costoOperativoTotaleConLinkedIn); el.costoSoluzioneLinkedInResult.textContent = formatCurrency(values.costoSoluzioneLinkedIn); el.costoMedioPerSelezioneConLinkedIn.textContent = formatCurrency(linkedIn.costoMedioPerSelezioneConLinkedIn);
      el.formulaConLinkedIn.textContent = `${translate('feeLine',{value:formatCurrency(linkedIn.feeSelezioneLinkedIn)})}\n+ ${translate('timeToHireLine',{value:formatCurrency(linkedIn.costoTimeToHireLinkedIn)})}\n+ ${translate('premiumLine',{value:formatCurrency(linkedIn.premioCambioLinkedIn)})}\n${translate('perHireLine',{value:formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn)})}\n\n${translate('multiplyLine',{value:formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn), count:values.numeroSelezioni})}\n${translate('solutionCostLine',{value:formatCurrency(values.costoSoluzioneLinkedIn)})}\n${translate('totalWithLine',{value:formatCurrency(linkedIn.costoTotaleConLinkedIn)})}`;
    }

    function updateComparison(values, base, linkedIn, comparison) {
      el.comparisonCostWithout.textContent = formatCurrency(base.costoTotaleSenzaLinkedIn); el.comparisonCostWith.textContent = formatCurrency(linkedIn.costoTotaleConLinkedIn); el.risparmioPerSelezione.textContent = formatCurrency(comparison.risparmioPerSelezione); el.risparmioOperativoTotale.textContent = formatCurrency(comparison.risparmioOperativoTotale); el.risparmioNetto.textContent = formatCurrency(comparison.risparmioNetto); el.risparmioNettoPercentuale.textContent = formatPercentage(comparison.risparmioNettoPercentuale); el.costoMedioPerSelezioneSenzaLinkedIn.textContent = formatCurrency(base.costoMedioPerSelezioneSenzaLinkedIn); el.comparisonAverageWith.textContent = formatCurrency(linkedIn.costoMedioPerSelezioneConLinkedIn);
      if (comparison.risparmioNetto > 0) { el.netSavingMessage.textContent = translate('positiveSavingMessage',{value:formatCurrency(comparison.risparmioNetto)}); setStatus('netSavingCard','positive'); } else if (comparison.risparmioNetto < 0) { el.netSavingMessage.textContent = translate('negativeSavingMessage',{value:formatCurrency(Math.abs(comparison.risparmioNetto))}); setStatus('netSavingCard','negative'); } else { el.netSavingMessage.textContent = translate('exactBreakEvenMessage'); setStatus('netSavingCard','neutral'); }
      const be = comparison.breakEven; if (be.unavailable) { el.breakEvenSelezioni.textContent = '—'; el.breakEvenMessage.textContent = translate('breakEvenUnavailable'); setStatus('breakEvenCard','negative'); } else { el.breakEvenSelezioni.textContent = `${be.breakEvenHires} ${translate('selectionsSuffix')}`; el.breakEvenMessage.textContent = `${translate('hiresToBreakEven',{count:be.breakEvenHires})} ${be.reached ? translate('breakEvenReached') : translate('remainingHiresToBreakEven',{count:be.remainingHires})}`; setStatus('breakEvenCard', be.reached ? 'positive' : 'neutral'); }
      const roi = comparison.roi; if (!roi.applicable) { el.roiLinkedIn.textContent = '—'; el.roiMessage.textContent = translate('roiNotApplicable'); setStatus('roiCard','neutral'); } else { el.roiLinkedIn.textContent = formatPercentage(roi.roi); if (roi.roi > 0) { el.roiMessage.textContent = translate('positiveRoiMessage',{value:formatCurrency(roi.benefitPerEuro)}); setStatus('roiCard','positive'); } else if (roi.roi < 0) { el.roiMessage.textContent = translate('negativeRoiMessage'); setStatus('roiCard','negative'); } else { el.roiMessage.textContent = translate('zeroRoiMessage'); setStatus('roiCard','neutral'); } }
      el.formulaConfronto.textContent = `${translate('withoutLine',{value:formatCurrency(base.costoTotaleSenzaLinkedIn)})}\n${translate('withLine',{value:formatCurrency(linkedIn.costoTotaleConLinkedIn)})}\n${translate('netSavingLine',{value:formatCurrency(comparison.risparmioNetto)})}`;
    }


    function openPrintWindow() {
      updateInterface();
      const validation = readAndValidateInputs();
      if (!validation.isValid) {
        const firstInvalidInput = inputIds.map((id) => inputs[id]).find((input) => input.getAttribute('aria-invalid') === 'true');
        if (firstInvalidInput) firstInvalidInput.focus();
        return;
      }

      const scenarioCards = document.querySelectorAll('.scenario-card');
      const linkedInCard = scenarioCards[1].cloneNode(true);
      const withoutLinkedInCard = scenarioCards[0].cloneNode(true);
      const comparisonCard = document.querySelector('.comparison-card').cloneNode(true);
      const printWindow = window.open('', '_blank');
      if (!printWindow) return;

      const printStyles = `
        @page { size: A4; margin: 10mm; }
        * { box-sizing: border-box; }
        body { margin: 0; background: #FFFFFF; color: #191919; font-family: Arial, sans-serif; font-size: 11px; line-height: 1.35; }
        h2, h3, p { margin-top: 0; }
        .print-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; align-items: start; }
        .scenario-card, .comparison-card { break-inside: avoid; page-break-inside: avoid; box-shadow: none; border: 1px solid #E0DFDC; border-radius: 12px; padding: 12px; background: #FFFFFF; overflow-wrap: anywhere; }
        .comparison-card { grid-column: 1 / -1; }
        .section-title { display: flex; align-items: center; gap: 0; margin-bottom: 10px; font-size: 15px; font-weight: 800; }
        .total-card { margin-bottom: 10px; padding: 12px; color: #FFFFFF; background: #0A66C2; border-radius: 10px; }
        .total-label { margin: 0 0 4px; font-weight: 700; }
        .total-value { margin: 0; font-size: 24px; line-height: 1; font-weight: 900; }
        .result-list { display: grid; gap: 0; margin: 0; }
        .result-row { display: flex; justify-content: space-between; gap: 12px; padding: 6px 0; border-bottom: 1px solid #E0DFDC; }
        .result-row dt { color: #666666; font-weight: 500; }
        .result-row dd { margin: 0; color: #191919; text-align: right; font-weight: 500; }
        .result-row.is-emphasis dt, .result-row.is-emphasis dd { color: #191919; font-weight: 800; }
        .note { margin: 8px 0; padding: 8px; color: #004182; background: #DCE6F1; border: 1px solid #70B5F9; border-radius: 8px; font-weight: 700; }
        .formula-box { margin-top: 10px; padding: 10px; background: #FFFFFF; border: 1px solid #E0DFDC; border-radius: 10px; }
        .formula-box h3 { margin-bottom: 6px; font-size: 12px; }
        pre { margin: 0; white-space: pre-wrap; color: #191919; font: 700 10px/1.45 Arial, sans-serif; }
        .highlight-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin: 10px 0; }
        .metric-card { padding: 10px; border: 1px solid #E0DFDC; border-radius: 10px; background: #FFFFFF; }
        .metric-card strong { display: block; font-size: 18px; margin-top: 4px; }
        .metric-card.positive { border-color: #057642; }
        .metric-card.neutral { border-color: #915907; }
        .metric-card.negative { border-color: #CC1016; }
        .status-text { margin: 6px 0 0; font-weight: 700; }
        @media print { .scenario-card, .comparison-card { break-inside: avoid; page-break-inside: avoid; } }
      `;

      printWindow.document.open();
      printWindow.document.write(`<!doctype html><html lang="${languageSettings[currentLanguage].htmlLang}"><head><meta charset="utf-8"><title>${translate('pageTitle')}</title><style>${printStyles}</style></head><body><main class="print-grid">${linkedInCard.outerHTML}${withoutLinkedInCard.outerHTML}${comparisonCard.outerHTML}</main><script>window.addEventListener('load', () => { window.print(); });<\/script></body></html>`);
      printWindow.document.close();
    }

    function updateInterface() { const { values, isValid } = readAndValidateInputs(); if (!isValid) { clearResults(); return; } const base = calculateBaseScenario(values); const linkedIn = calculateLinkedInScenario(values, base); const comparison = calculateComparison(values, base, linkedIn); updateBaseScenario(values, base); updateLinkedInScenario(values, base, linkedIn); updateComparison(values, base, linkedIn, comparison); }
    function resetValues() { inputIds.forEach((id) => { inputs[id].value = defaults[id]; }); updateInterface(); }
    languageButtons.forEach((button) => button.addEventListener('click', () => applyLanguage(button.dataset.language)));
    themeToggle.addEventListener('click', () => applyTheme(currentTheme === 'dark' ? 'light' : 'dark'));
    form.addEventListener('input', updateInterface); form.addEventListener('submit', (event) => { event.preventDefault(); updateInterface(); }); resetButton.addEventListener('click', resetValues); printButton.addEventListener('click', openPrintWindow);
    applyTheme(currentTheme); applyLanguage(currentLanguage);
  </script>
</body>
</html>
