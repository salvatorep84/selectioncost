<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title data-i18n="pageTitle"></title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f4f7fb;
      --bg-start: #eef4ff;
      --bg-end: #ffffff;
      --card: #ffffff;
      --text: #172033;
      --muted: #5f6b7a;
      --primary: #0A66C2;
      --primary-dark: #084f97;
      --border: #d8dee8;
      --error: #b42318;
      --error-bg: #fff1f0;
      --success-bg: #eef6ff;
      --surface: #fbfdff;
      --input-bg: #ffffff;
      --secondary-bg: #ffffff;
      --secondary-hover: #f8fafc;
      --row-border: #e8edf5;
      --formula-text: #263247;
      --note-text: #12335b;
      --note-border: #c7ddff;
      --card-border: rgba(216, 222, 232, 0.8);
      --shadow: 0 18px 45px rgba(16, 24, 40, 0.10);
      --radius: 18px;
    }

    html[data-theme="dark"] {
      color-scheme: dark;
      --bg: #0f1722;
      --bg-start: #0b1220;
      --bg-end: #111827;
      --card: #172131;
      --text: #f2f5f9;
      --muted: #aeb8c7;
      --primary-dark: #2b7fd3;
      --border: #344258;
      --error: #ffb4ab;
      --error-bg: #351a1d;
      --success-bg: #142b42;
      --surface: #121c2a;
      --input-bg: #0f1825;
      --secondary-bg: #1b2636;
      --secondary-hover: #243246;
      --row-border: #2b384a;
      --formula-text: #e5ebf3;
      --note-text: #d8eaff;
      --note-border: #28547d;
      --card-border: rgba(52, 66, 88, 0.9);
      --shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, var(--bg-start) 0%, var(--bg) 38%, var(--bg-end) 100%);
      line-height: 1.5;
    }

    main {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
      padding: 40px 0;
    }

    .page-controls {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 12px;
      margin-bottom: 22px;
    }

    .language-selector {
      display: inline-flex;
      gap: 4px;
      padding: 4px;
      background: var(--secondary-bg);
      border: 1px solid var(--border);
      border-radius: 999px;
    }

    .language-button,
    .theme-toggle {
      min-height: 38px;
      padding: 8px 12px;
      color: var(--text);
      background: transparent;
      border: 1px solid transparent;
      border-radius: 999px;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
    }

    .language-button[aria-pressed="true"] {
      color: #ffffff;
      background: var(--primary);
    }

    .theme-toggle {
      min-width: 42px;
      background: var(--secondary-bg);
      border-color: var(--border);
      font-size: 1rem;
    }

    .language-button:focus-visible,
    .theme-toggle:focus-visible,
    button:focus-visible {
      outline: 3px solid rgba(10, 102, 194, 0.35);
      outline-offset: 2px;
    }

    .hero { text-align: center; margin-bottom: 28px; }

    .eyebrow {
      margin: 0 0 8px;
      color: var(--primary);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .intro {
      max-width: 720px;
      margin: 0 auto;
      color: var(--muted);
      font-size: 1.05rem;
    }

    .tool-card {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
      gap: 28px;
      padding: 28px;
      background: var(--card);
      border: 1px solid var(--card-border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    form { display: grid; gap: 24px; }

    fieldset {
      margin: 0;
      padding: 0;
      border: 0;
    }

    legend, .results-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
      font-size: 1.15rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .section-number {
      display: inline-grid;
      width: 28px;
      height: 28px;
      place-items: center;
      border-radius: 999px;
      color: #ffffff;
      background: var(--primary);
      font-size: 0.85rem;
      font-weight: 800;
      flex: 0 0 auto;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .field { display: grid; gap: 7px; }

    label {
      color: var(--formula-text);
      font-size: 0.94rem;
      font-weight: 700;
    }

    .input-wrapper { position: relative; }

    input {
      width: 100%;
      min-height: 48px;
      padding: 12px 44px 12px 14px;
      color: var(--text);
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      font: inherit;
      outline: none;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(10, 102, 194, 0.14);
    }

    input[aria-invalid="true"] {
      border-color: var(--error);
      background: var(--error-bg);
    }

    .suffix {
      position: absolute;
      top: 50%;
      right: 14px;
      transform: translateY(-50%);
      color: var(--muted);
      font-weight: 700;
      pointer-events: none;
    }

    .error-message {
      min-height: 18px;
      color: var(--error);
      font-size: 0.84rem;
      font-weight: 650;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      padding-top: 4px;
    }

    button {
      min-height: 46px;
      padding: 11px 18px;
      border: 1px solid transparent;
      border-radius: 999px;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
    }

    .btn-primary { color: #ffffff; background: var(--primary); }
    .btn-primary:hover { background: var(--primary-dark); }
    .btn-secondary { color: var(--text); background: var(--input-bg); border-color: var(--border); }
    .btn-secondary:hover { background: var(--secondary-hover); }

    .results-panel {
      align-self: start;
      padding: 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
    }

    .total-card {
      margin-bottom: 18px;
      padding: 22px;
      color: #ffffff;
      background: linear-gradient(135deg, #0A66C2 0%, #073b70 100%);
      border-radius: 16px;
    }

    .total-label { margin: 0 0 8px; font-weight: 700; opacity: 0.9; }

    .total-value {
      margin: 0;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .daily-note {
      margin: 12px 0 0;
      padding: 12px 14px;
      color: var(--note-text);
      background: var(--success-bg);
      border: 1px solid var(--note-border);
      border-radius: 12px;
      font-weight: 700;
    }

    .result-list {
      display: grid;
      gap: 10px;
      margin: 0;
    }

    .result-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 12px 0;
      border-bottom: 1px solid var(--row-border);
    }

    .result-row dt { color: var(--muted); font-weight: 500; }
    .result-row dd { margin: 0; text-align: right; font-weight: 500; }
    .result-row.is-emphasis dt,
    .result-row.is-emphasis dd { font-weight: 850; }

    .formula-box {
      margin-top: 18px;
      padding: 16px;
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
    }

    .formula-box h3 { margin: 0 0 10px; font-size: 1rem; }

    pre {
      margin: 0;
      white-space: pre-wrap;
      color: var(--formula-text);
      font: 700 0.98rem/1.6 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .invalid-state {
      color: var(--error);
      font-weight: 750;
    }

    @media (max-width: 880px) {
      .tool-card { grid-template-columns: 1fr; padding: 22px; }
      .results-panel { position: static; }
    }

    @media (max-width: 620px) {
      main { width: min(100% - 20px, 1120px); padding: 24px 0; }
      .tool-card { padding: 18px; gap: 22px; }
      .form-grid { grid-template-columns: 1fr; }
      .page-controls { justify-content: center; flex-wrap: wrap; }
      .actions { flex-direction: column; }
      button { width: 100%; }
      .result-row { align-items: flex-start; flex-direction: column; gap: 4px; }
      .result-row dd { text-align: left; }
    }
  </style>
</head>
<body>
  <main>
    <div class="page-controls">
      <div class="language-selector" role="group" data-i18n-aria-label="languageSelector">
        <button class="language-button" type="button" data-language="it" aria-label="Italiano" aria-pressed="true">IT</button>
        <button class="language-button" type="button" data-language="en" aria-label="English" aria-pressed="false">EN</button>
        <button class="language-button" type="button" data-language="es" aria-label="Español" aria-pressed="false">ES</button>
      </div>
      <button class="theme-toggle" id="theme-toggle" type="button" data-i18n-aria-label="enableDarkMode">🌙</button>
    </div>

    <header class="hero">
      <p class="eyebrow" data-i18n="eyebrow"></p>
      <h1 data-i18n="heading"></h1>
      <p class="intro" data-i18n="intro"></p>
    </header>

    <section class="tool-card" data-i18n-aria-label="calculatorAriaLabel" aria-label="Tool di calcolo del costo di sostituzione di un dipendente">
      <form id="roi-form" novalidate>
        <fieldset>
          <legend><span class="section-number">1</span><span data-i18n="employeeData"></span></legend>
          <div class="form-grid">
            <div class="field">
              <label for="ral" data-i18n="currentSalary"></label>
              <div class="input-wrapper">
                <input id="ral" name="ral" type="number" min="0" step="100" value="35000" required inputmode="decimal" aria-describedby="ral-error">
                <span class="suffix" data-i18n="euroSuffix"></span>
              </div>
              <span id="ral-error" class="error-message" aria-live="polite"></span>
            </div>

            <div class="field">
              <label for="produttivitaAnnua" data-i18n="annualProductivity"></label>
              <div class="input-wrapper">
                <input id="produttivitaAnnua" name="produttivitaAnnua" type="number" min="0" step="100" value="33000" inputmode="decimal" aria-describedby="produttivitaAnnua-error">
                <span class="suffix" data-i18n="euroSuffix"></span>
              </div>
              <span id="produttivitaAnnua-error" class="error-message" aria-live="polite"></span>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend><span class="section-number">2</span><span data-i18n="recruitmentCostsAndTiming"></span></legend>
          <div class="form-grid">
            <div class="field">
              <label for="percentualeFee" data-i18n="recruitmentFee"></label>
              <div class="input-wrapper">
                <input id="percentualeFee" name="percentualeFee" type="number" min="0" max="100" step="0.1" value="15" inputmode="decimal" aria-describedby="percentualeFee-error">
                <span class="suffix">%</span>
              </div>
              <span id="percentualeFee-error" class="error-message" aria-live="polite"></span>
            </div>

            <div class="field">
              <label for="percentualePremio" data-i18n="changePremium"></label>
              <div class="input-wrapper">
                <input id="percentualePremio" name="percentualePremio" type="number" min="0" max="100" step="0.1" value="20" inputmode="decimal" aria-describedby="percentualePremio-error">
                <span class="suffix">%</span>
              </div>
              <span id="percentualePremio-error" class="error-message" aria-live="polite"></span>
            </div>

            <div class="field">
              <label for="giorniTimeToHire" data-i18n="timeToHire"></label>
              <div class="input-wrapper">
                <input id="giorniTimeToHire" name="giorniTimeToHire" type="number" min="0" step="1" value="45" inputmode="numeric" aria-describedby="giorniTimeToHire-error">
                <span class="suffix" data-i18n="daysSuffix"></span>
              </div>
              <span id="giorniTimeToHire-error" class="error-message" aria-live="polite"></span>
            </div>

            <div class="field">
              <label for="giorniLavorativiAnnui" data-i18n="annualWorkingDays"></label>
              <div class="input-wrapper">
                <input id="giorniLavorativiAnnui" name="giorniLavorativiAnnui" type="number" min="1" step="1" value="250" inputmode="numeric" aria-describedby="giorniLavorativiAnnui-error">
                <span class="suffix" data-i18n="daysSuffix"></span>
              </div>
              <span id="giorniLavorativiAnnui-error" class="error-message" aria-live="polite"></span>
            </div>
          </div>
        </fieldset>

        <div class="actions">
          <button class="btn-secondary" type="button" id="reset-button" data-i18n="resetButton"></button>
        </div>
      </form>

      <aside class="results-panel" aria-live="polite">
        <h2 class="results-title"><span class="section-number">3</span><span data-i18n="economicResult"></span></h2>
        <div class="total-card">
          <p class="total-label" data-i18n="totalReplacementCost"></p>
          <p class="total-value" id="costoTotale">€ 0</p>
        </div>

        <p class="daily-note" id="daily-note"></p>

        <dl class="result-list">
          <div class="result-row"><dt data-i18n="dailyProductivity"></dt><dd id="produttivitaGiornaliera">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="timeToHireCost"></dt><dd id="costoTimeToHire">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="changePremium"></dt><dd id="premioCambio">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="estimatedNewSalary"></dt><dd id="nuovaRalStimata">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="recruitmentFee"></dt><dd id="feeSelezione">€ 0</dd></div>
        </dl>

        <div class="formula-box">
          <h3 data-i18n="calculationSummary"></h3>
          <pre id="formula-summary"></pre>
        </div>
      </aside>
    </section>
  </main>

  <script>
