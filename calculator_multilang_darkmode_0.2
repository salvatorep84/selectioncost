      es: {
        pageTitle: 'Calculadora del coste de sustitución de empleados',
        eyebrow: 'RR. HH. • Finanzas • Adquisición de talento',
        heading: 'Calculadora del coste de sustitución de empleados',
        intro: 'Calcula el coste económico total de sustituir a un empleado, incluyendo los honorarios de selección, el coste del tiempo de contratación y el incremento salarial necesario para atraer a un sustituto.',
