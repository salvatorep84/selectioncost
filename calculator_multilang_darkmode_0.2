        enableDarkMode: 'Activar modo oscuro',
        enableLightMode: 'Activar modo claro',
        euroSuffix: '€',
        daysSuffix: 'días'
      }
    };

    const defaults = {
      ral: 35000,
      percentualeFee: 15,
      percentualePremio: 20,
      produttivitaAnnua: 33000,
      giorniTimeToHire: 45,
      giorniLavorativiAnnui: 250
    };

    let currentLanguage = getStoredValue(storageKeys.language, 'it');
    if (!translations[currentLanguage]) currentLanguage = 'it';
    let currentTheme = getInitialTheme();
    let currencyFormatter = getCurrencyFormatter();

    const form = document.getElementById('roi-form');
    const resetButton = document.getElementById('reset-button');
    const themeToggle = document.getElementById('theme-toggle');
    const languageButtons = document.querySelectorAll('.language-button');
    const inputIds = Object.keys(defaults);
    const inputs = Object.fromEntries(inputIds.map((id) => [id, document.getElementById(id)]));

    const resultElements = {
      feeSelezione: document.getElementById('feeSelezione'),
      premioCambio: document.getElementById('premioCambio'),
      nuovaRalStimata: document.getElementById('nuovaRalStimata'),
      produttivitaGiornaliera: document.getElementById('produttivitaGiornaliera'),
      costoTimeToHire: document.getElementById('costoTimeToHire'),
      costoTotale: document.getElementById('costoTotale'),
      dailyNote: document.getElementById('daily-note'),
      formulaSummary: document.getElementById('formula-summary')
    };

    function getStoredValue(key, fallback) {
      try { return localStorage.getItem(key) || fallback; } catch { return fallback; }
    }

    function setStoredValue(key, value) {
      try { localStorage.setItem(key, value); } catch { /* localStorage unavailable */ }
    }

    function translate(key, variables = {}) {
      let text = translations[currentLanguage][key] || translations.it[key] || '';
      Object.entries(variables).forEach(([name, value]) => {
        text = text.replaceAll(`{${name}}`, value);
      });
      return text;
    }

    // Aggiorna testi statici, attributi accessibili e locale attivo.
    function applyLanguage(language) {
      currentLanguage = translations[language] ? language : 'it';
      document.documentElement.lang = languageSettings[currentLanguage].htmlLang;
      document.querySelectorAll('[data-i18n]').forEach((element) => {
        element.textContent = translate(element.dataset.i18n);
      });
      document.querySelectorAll('[data-i18n-aria-label]').forEach((element) => {
        element.setAttribute('aria-label', translate(element.dataset.i18nAriaLabel));
      });
      document.querySelectorAll('[data-i18n-title]').forEach((element) => {
        element.setAttribute('title', translate(element.dataset.i18nTitle));
      });
      languageButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.language === currentLanguage));
      });
      document.title = translate('pageTitle');
      currencyFormatter = getCurrencyFormatter();
      updateThemeButton();
      setStoredValue(storageKeys.language, currentLanguage);
      updateInterface();
    }

    function getCurrencyFormatter() {
      return new Intl.NumberFormat(languageSettings[currentLanguage].locale, {
        style: 'currency',
        currency: 'EUR',
        maximumFractionDigits: 0
      });
    }

    function formatCurrency(value) {
      return Number.isFinite(value) ? currencyFormatter.format(value) : currencyFormatter.format(0);
    }

    function getInitialTheme() {
      const storedTheme = getStoredValue(storageKeys.theme, '');
      if (storedTheme === 'dark' || storedTheme === 'light') return storedTheme;
      return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    // Applica tema e aggiorna attributi accessibili del controllo.
    function applyTheme(theme) {
      currentTheme = theme === 'dark' ? 'dark' : 'light';
      document.documentElement.dataset.theme = currentTheme;
      updateThemeButton();
      setStoredValue(storageKeys.theme, currentTheme);
    }

    function updateThemeButton() {
      const nextModeKey = currentTheme === 'dark' ? 'enableLightMode' : 'enableDarkMode';
      themeToggle.textContent = currentTheme === 'dark' ? '☀' : '🌙';
      themeToggle.setAttribute('aria-label', translate(nextModeKey));
      themeToggle.setAttribute('title', translate(nextModeKey));
    }

    function setFieldError(id, message) {
      const errorElement = document.getElementById(`${id}-error`);
      inputs[id].setAttribute('aria-invalid', message ? 'true' : 'false');
      errorElement.textContent = message;
    }

    // Legge e valida tutti gli input del form.
    function readAndValidateInputs() {
      const values = {};
      const errors = {};

      inputIds.forEach((id) => {
        const rawValue = inputs[id].value.trim();
        const value = Number(rawValue);
        values[id] = value;

        if (rawValue === '') {
          errors[id] = id === 'ral' ? translate('salaryRequired') : translate('valueRequired');
          return;
        }

        if (!Number.isFinite(value)) {
          errors[id] = translate('invalidNumber');
          return;
        }

        if (value < 0) {
          errors[id] = translate('negativeValue');
        }
      });

      ['percentualeFee', 'percentualePremio'].forEach((id) => {
        if (!errors[id] && values[id] > 100) {
          errors[id] = translate('percentageAbove100');
        }
      });

      ['giorniTimeToHire', 'giorniLavorativiAnnui'].forEach((id) => {
        if (!errors[id] && !Number.isInteger(values[id])) {
          errors[id] = translate('integerDays');
        }
      });

      if (!errors.giorniLavorativiAnnui && values.giorniLavorativiAnnui <= 0) {
        errors.giorniLavorativiAnnui = translate('workingDaysAboveZero');
      }

      inputIds.forEach((id) => setFieldError(id, errors[id] || ''));

      return { values, isValid: Object.keys(errors).length === 0 };
    }

    // Esegue il calcolo economico principale.
    function calculateCosts(values) {
      const premioCambio = values.ral * (values.percentualePremio / 100);
      const feeSelezione = (values.ral + premioCambio) * (values.percentualeFee / 100);
      const produttivitaGiornaliera = values.produttivitaAnnua / values.giorniLavorativiAnnui;
      const costoTimeToHire = produttivitaGiornaliera * values.giorniTimeToHire;
      const costoTotale = feeSelezione + premioCambio + costoTimeToHire;
      const nuovaRalStimata = values.ral + premioCambio;
      return { feeSelezione, premioCambio, produttivitaGiornaliera, costoTimeToHire, costoTotale, nuovaRalStimata };
    }

    function clearResults() {
      resultElements.costoTotale.textContent = formatCurrency(0);
      resultElements.dailyNote.textContent = translate('invalidDailyCost');
      resultElements.dailyNote.classList.add('invalid-state');
      ['feeSelezione', 'premioCambio', 'nuovaRalStimata', 'produttivitaGiornaliera', 'costoTimeToHire'].forEach((id) => {
        resultElements[id].textContent = formatCurrency(0);
      });
      resultElements.formulaSummary.textContent = translate('invalidSummary');
    }

    // Aggiorna l'interfaccia con i risultati calcolati.
    function updateInterface() {
      const { values, isValid } = readAndValidateInputs();
      if (!isValid) {
        clearResults();
        return;
      }
      const results = calculateCosts(values);
      resultElements.dailyNote.classList.remove('invalid-state');
      resultElements.feeSelezione.textContent = formatCurrency(results.feeSelezione);
      resultElements.premioCambio.textContent = formatCurrency(results.premioCambio);
      resultElements.nuovaRalStimata.textContent = formatCurrency(results.nuovaRalStimata);
      resultElements.produttivitaGiornaliera.textContent = formatCurrency(results.produttivitaGiornaliera);
      resultElements.costoTimeToHire.textContent = formatCurrency(results.costoTimeToHire);
      resultElements.costoTotale.textContent = formatCurrency(results.costoTotale);
      resultElements.dailyNote.textContent = translate('dailyVacancyCost', { value: formatCurrency(results.produttivitaGiornaliera) });
      resultElements.formulaSummary.textContent = `${translate('feeSummary', { value: formatCurrency(results.feeSelezione) })}\n+ ${translate('timeToHireSummary', { value: formatCurrency(results.costoTimeToHire) })}\n+ ${translate('changePremiumSummary', { value: formatCurrency(results.premioCambio) })}\n= ${translate('totalSummary', { value: formatCurrency(results.costoTotale) })}`;
    }

    // Ripristina i valori predefiniti del tool.
    function resetValues() {
      inputIds.forEach((id) => { inputs[id].value = defaults[id]; });
      updateInterface();
    }

    languageButtons.forEach((button) => {
      button.addEventListener('click', () => applyLanguage(button.dataset.language));
    });
    themeToggle.addEventListener('click', () => applyTheme(currentTheme === 'dark' ? 'light' : 'dark'));
    form.addEventListener('input', updateInterface);
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      updateInterface();
    });
    resetButton.addEventListener('click', resetValues);

    applyTheme(currentTheme);
    applyLanguage(currentLanguage);
  </script>
</body>
</html>
