        percentageAbove100: 'El porcentaje no puede superar el 100%.',
        integerDays: 'Introduce un número entero de días.',
        workingDaysAboveZero: 'Los días laborables anuales deben ser superiores a cero.',
        languageSelector: 'Seleccionar idioma',
