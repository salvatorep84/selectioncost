      el.formulaSenzaLinkedIn.textContent = `${translate('feeLine',{value:formatCurrency(base.feeSelezione)})}\n+ ${translate('timeToHireLine',{value:formatCurrency(base.costoTimeToHire)})}\n+ ${translate('premiumLine',{value:formatCurrency(base.premioCambio)})}\n${translate('perHireLine',{value:formatCurrency(base.costoSingolaSelezioneSenzaLinkedIn)})}\n\n${translate('multiplyLine',{value:formatCurrency(base.costoSingolaSelezioneSenzaLinkedIn), count:values.numeroSelezioni})}\n${translate('totalWithoutLine',{value:formatCurrency(base.costoTotaleSenzaLinkedIn)})}`;
