    function updateLinkedInScenario(values, base, linkedIn) {
      el.costoTotaleConLinkedIn.textContent = formatCurrency(linkedIn.costoTotaleConLinkedIn); el.timeToHireIniziale.textContent = `${formatDays(values.giorniTimeToHire)} ${translate('daysSuffix')}`; el.riduzioneTimeToHireLinkedInResult.textContent = formatPercentage(values.riduzioneTimeToHireLinkedIn); el.giorniTimeToHireLinkedIn.textContent = `${formatDays(linkedIn.giorniTimeToHireLinkedIn)} ${translate('daysSuffix')}`; el.costoTimeToHireLinkedIn.textContent = formatCurrency(linkedIn.costoTimeToHireLinkedIn); el.premioCambioInizialeLinkedIn.textContent = formatCurrency(base.premioCambio); el.riduzionePremioLinkedInResult.textContent = formatPercentage(values.riduzionePremioLinkedIn); el.premioCambioLinkedIn.textContent = formatCurrency(linkedIn.premioCambioLinkedIn); el.nuovaRalStimataLinkedIn.textContent = formatCurrency(linkedIn.nuovaRalStimataLinkedIn); el.feeSelezioneLinkedIn.textContent = formatCurrency(linkedIn.feeSelezioneLinkedIn); el.costoSingolaSelezioneConLinkedIn.textContent = formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn); el.costoOperativoTotaleConLinkedIn.textContent = formatCurrency(linkedIn.costoOperativoTotaleConLinkedIn); el.costoSoluzioneLinkedInResult.textContent = formatCurrency(values.costoSoluzioneLinkedIn); el.costoMedioPerSelezioneConLinkedIn.textContent = formatCurrency(linkedIn.costoMedioPerSelezioneConLinkedIn);
      el.formulaConLinkedIn.textContent = `${translate('feeLine',{value:formatCurrency(linkedIn.feeSelezioneLinkedIn)})}\n+ ${translate('timeToHireLine',{value:formatCurrency(linkedIn.costoTimeToHireLinkedIn)})}\n+ ${translate('premiumLine',{value:formatCurrency(linkedIn.premioCambioLinkedIn)})}\n${translate('perHireLine',{value:formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn)})}\n\n${translate('multiplyLine',{value:formatCurrency(linkedIn.costoSingolaSelezioneConLinkedIn), count:values.numeroSelezioni})}\n${translate('solutionCostLine',{value:formatCurrency(values.costoSoluzioneLinkedIn)})}\n${translate('totalWithLine',{value:formatCurrency(linkedIn.costoTotaleConLinkedIn)})}`;
    }

    function updateComparison(values, base, linkedIn, comparison) {
      el.comparisonCostWithout.textContent = formatCurrency(base.costoTotaleSenzaLinkedIn); el.comparisonCostWith.textContent = formatCurrency(linkedIn.costoTotaleConLinkedIn); el.risparmioPerSelezione.textContent = formatCurrency(comparison.risparmioPerSelezione); el.risparmioOperativoTotale.textContent = formatCurrency(comparison.risparmioOperativoTotale); el.risparmioNetto.textContent = formatCurrency(comparison.risparmioNetto); el.risparmioNettoPercentuale.textContent = formatPercentage(comparison.risparmioNettoPercentuale); el.costoMedioPerSelezioneSenzaLinkedIn.textContent = formatCurrency(base.costoMedioPerSelezioneSenzaLinkedIn); el.comparisonAverageWith.textContent = formatCurrency(linkedIn.costoMedioPerSelezioneConLinkedIn);
      if (comparison.risparmioNetto > 0) { el.netSavingMessage.textContent = translate('positiveSavingMessage',{value:formatCurrency(comparison.risparmioNetto)}); setStatus('netSavingCard','positive'); } else if (comparison.risparmioNetto < 0) { el.netSavingMessage.textContent = translate('negativeSavingMessage',{value:formatCurrency(Math.abs(comparison.risparmioNetto))}); setStatus('netSavingCard','negative'); } else { el.netSavingMessage.textContent = translate('exactBreakEvenMessage'); setStatus('netSavingCard','neutral'); }
      const be = comparison.breakEven; if (be.unavailable) { el.breakEvenSelezioni.textContent = '—'; el.breakEvenMessage.textContent = translate('breakEvenUnavailable'); setStatus('breakEvenCard','negative'); } else { el.breakEvenSelezioni.textContent = `${be.breakEvenHires} ${translate('selectionsSuffix')}`; el.breakEvenMessage.textContent = `${translate('hiresToBreakEven',{count:be.breakEvenHires})} ${be.reached ? translate('breakEvenReached') : translate('remainingHiresToBreakEven',{count:be.remainingHires})}`; setStatus('breakEvenCard', be.reached ? 'positive' : 'neutral'); }
      const roi = comparison.roi; if (!roi.applicable) { el.roiLinkedIn.textContent = '—'; el.roiMessage.textContent = translate('roiNotApplicable'); setStatus('roiCard','neutral'); } else { el.roiLinkedIn.textContent = formatPercentage(roi.roi); if (roi.roi > 0) { el.roiMessage.textContent = translate('positiveRoiMessage',{value:formatCurrency(roi.benefitPerEuro)}); setStatus('roiCard','positive'); } else if (roi.roi < 0) { el.roiMessage.textContent = translate('negativeRoiMessage'); setStatus('roiCard','negative'); } else { el.roiMessage.textContent = translate('zeroRoiMessage'); setStatus('roiCard','neutral'); } }
      el.formulaConfronto.textContent = `${translate('withoutLine',{value:formatCurrency(base.costoTotaleSenzaLinkedIn)})}\n${translate('withLine',{value:formatCurrency(linkedIn.costoTotaleConLinkedIn)})}\n${translate('netSavingLine',{value:formatCurrency(comparison.risparmioNetto)})}`;
    }

    function updateInterface() { const { values, isValid } = readAndValidateInputs(); if (!isValid) { clearResults(); return; } const base = calculateBaseScenario(values); const linkedIn = calculateLinkedInScenario(values, base); const comparison = calculateComparison(values, base, linkedIn); updateBaseScenario(values, base); updateLinkedInScenario(values, base, linkedIn); updateComparison(values, base, linkedIn, comparison); }
    function resetValues() { inputIds.forEach((id) => { inputs[id].value = defaults[id]; }); updateInterface(); }
    languageButtons.forEach((button) => button.addEventListener('click', () => applyLanguage(button.dataset.language)));
    themeToggle.addEventListener('click', () => applyTheme(currentTheme === 'dark' ? 'light' : 'dark'));
    form.addEventListener('input', updateInterface); form.addEventListener('submit', (event) => { event.preventDefault(); updateInterface(); }); resetButton.addEventListener('click', resetValues);
    applyTheme(currentTheme); applyLanguage(currentLanguage);
  </script>
</body>
</html>
