<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title data-i18n="pageTitle"></title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f4f7fb; --bg-start: #eef4ff; --bg-end: #ffffff; --card: #ffffff;
      --text: #172033; --muted: #5f6b7a; --primary: #0A66C2; --primary-dark: #084f97;
      --border: #d8dee8; --error: #b42318; --error-bg: #fff1f0; --success: #087443;
      --success-bg: #ecfdf3; --warning: #9a6700; --warning-bg: #fffaeb; --negative: #b42318;
      --surface: #fbfdff; --input-bg: #ffffff; --secondary-bg: #ffffff; --secondary-hover: #f8fafc;
      --row-border: #e8edf5; --formula-text: #263247; --note-text: #12335b; --note-border: #c7ddff;
      --card-border: rgba(216, 222, 232, 0.8); --shadow: 0 18px 45px rgba(16, 24, 40, 0.10); --radius: 18px;
    }

    html[data-theme="dark"] {
      color-scheme: dark;
      --bg: #0f1722; --bg-start: #0b1220; --bg-end: #111827; --card: #172131;
      --text: #f2f5f9; --muted: #aeb8c7; --primary-dark: #2b7fd3; --border: #344258;
      --error: #ffb4ab; --error-bg: #351a1d; --success: #78d8a3; --success-bg: #12301f;
      --warning: #ffd166; --warning-bg: #332509; --negative: #ffb4ab; --surface: #121c2a;
      --input-bg: #0f1825; --secondary-bg: #1b2636; --secondary-hover: #243246; --row-border: #2b384a;
      --formula-text: #e5ebf3; --note-text: #d8eaff; --note-border: #28547d; --card-border: rgba(52, 66, 88, 0.9);
      --shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
    }

    * { box-sizing: border-box; }
    body { margin: 0; min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; color: var(--text); background: linear-gradient(180deg, var(--bg-start), var(--bg) 38%, var(--bg-end)); line-height: 1.5; }
    main { width: min(1240px, calc(100% - 32px)); margin: 0 auto; padding: 40px 0; }
    .page-controls { display: flex; justify-content: flex-end; align-items: center; gap: 12px; margin-bottom: 22px; }
    .language-selector { display: inline-flex; gap: 4px; padding: 4px; background: var(--secondary-bg); border: 1px solid var(--border); border-radius: 999px; }
    .language-button, .theme-toggle { min-height: 38px; padding: 8px 12px; color: var(--text); background: transparent; border: 1px solid transparent; border-radius: 999px; font: inherit; font-weight: 800; cursor: pointer; }
    .language-button[aria-pressed="true"] { color: #fff; background: var(--primary); }
    .theme-toggle { min-width: 42px; background: var(--secondary-bg); border-color: var(--border); }
    button:focus-visible, input:focus-visible, .language-button:focus-visible, .theme-toggle:focus-visible { outline: 3px solid rgba(10, 102, 194, 0.35); outline-offset: 2px; }
    .hero { text-align: center; margin-bottom: 28px; }
    .eyebrow { margin: 0 0 8px; color: var(--primary); font-size: .82rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
    h1 { margin: 0 0 12px; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.05; letter-spacing: -.04em; }
    .intro { max-width: 820px; margin: 0 auto; color: var(--muted); font-size: 1.05rem; }
    .tool-card, .scenario-card, .comparison-card { background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius); box-shadow: var(--shadow); }
    .tool-card { padding: 28px; }
    form { display: grid; gap: 24px; }
    fieldset { margin: 0; padding: 0; border: 0; }
    legend, .section-title { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; font-size: 1.15rem; font-weight: 850; letter-spacing: -.02em; }
    .section-number { display: inline-grid; width: 28px; height: 28px; place-items: center; border-radius: 999px; color: #fff; background: var(--primary); font-size: .85rem; font-weight: 850; flex: 0 0 auto; }
    .form-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
    .field { display: grid; gap: 7px; }
    label { color: var(--formula-text); font-size: .94rem; font-weight: 750; }
    .help-text { margin: 0; color: var(--muted); font-size: .86rem; }
    .input-wrapper { position: relative; }
    input { width: 100%; min-height: 48px; padding: 12px 44px 12px 14px; color: var(--text); background: var(--input-bg); border: 1px solid var(--border); border-radius: 12px; font: inherit; outline: none; transition: border-color .18s ease, box-shadow .18s ease; }
    input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(10, 102, 194, .14); }
    input[aria-invalid="true"] { border-color: var(--error); background: var(--error-bg); }
    .suffix { position: absolute; top: 50%; right: 14px; transform: translateY(-50%); color: var(--muted); font-weight: 750; pointer-events: none; }
    .error-message { min-height: 18px; color: var(--error); font-size: .84rem; font-weight: 700; }
    .actions { display: flex; flex-wrap: wrap; gap: 12px; padding-top: 4px; }
    button { min-height: 46px; padding: 11px 18px; border: 1px solid transparent; border-radius: 999px; font: inherit; font-weight: 850; cursor: pointer; }
    .btn-secondary { color: var(--text); background: var(--secondary-bg); border-color: var(--border); }
    .btn-secondary:hover { background: var(--secondary-hover); }
    .scenario-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 22px; margin-top: 24px; }
    .scenario-card, .comparison-card { padding: 24px; }
    .comparison-card { margin-top: 22px; }
    .total-card { margin-bottom: 18px; padding: 22px; color: #fff; background: linear-gradient(135deg, #0A66C2 0%, #073b70 100%); border-radius: 16px; }
    .total-label { margin: 0 0 8px; font-weight: 750; opacity: .92; }
    .total-value { margin: 0; font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1; font-weight: 950; letter-spacing: -.05em; }
    .result-list { display: grid; gap: 0; margin: 0; }
    .result-row { display: flex; justify-content: space-between; gap: 18px; padding: 11px 0; border-bottom: 1px solid var(--row-border); }
    .result-row dt { color: var(--muted); font-weight: 500; }
    .result-row dd { margin: 0; text-align: right; font-weight: 500; }
    .result-row.is-emphasis dt, .result-row.is-emphasis dd { font-weight: 850; color: var(--text); }
    .note { margin: 12px 0 0; padding: 12px 14px; color: var(--note-text); background: var(--success-bg); border: 1px solid var(--note-border); border-radius: 12px; font-weight: 700; }
    .formula-box { margin-top: 18px; padding: 16px; background: var(--input-bg); border: 1px solid var(--border); border-radius: 14px; }
    .formula-box h3 { margin: 0 0 10px; font-size: 1rem; }
    pre { margin: 0; white-space: pre-wrap; color: var(--formula-text); font: 700 .95rem/1.6 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    .highlight-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin: 18px 0; }
    .metric-card { padding: 16px; border: 1px solid var(--border); border-radius: 14px; background: var(--surface); }
    .metric-card strong { display: block; font-size: clamp(1.3rem, 3vw, 2rem); line-height: 1.1; margin-top: 6px; }
    .metric-card.positive { border-color: var(--success); }
    .metric-card.neutral { border-color: var(--warning); }
    .metric-card.negative { border-color: var(--negative); }
    .status-text { margin: 10px 0 0; font-weight: 750; }
    .positive-text { color: var(--success); } .neutral-text { color: var(--warning); } .negative-text { color: var(--negative); }
    .invalid-state { color: var(--error); font-weight: 750; }
    @media (max-width: 980px) { .form-grid, .scenario-grid, .highlight-grid { grid-template-columns: 1fr; } }
    @media (max-width: 620px) { main { width: min(100% - 20px, 1240px); padding: 24px 0; } .tool-card, .scenario-card, .comparison-card { padding: 18px; } .page-controls { justify-content: center; flex-wrap: wrap; } .actions { flex-direction: column; } button { width: 100%; } .result-row { align-items: flex-start; flex-direction: column; gap: 4px; } .result-row dd { text-align: left; } }
  </style>
</head>
<body>
  <main>
    <div class="page-controls">
      <div class="language-selector" role="group" data-i18n-aria-label="languageSelector">
        <button class="language-button" type="button" data-language="it" aria-label="Italiano" aria-pressed="true">IT</button>
        <button class="language-button" type="button" data-language="en" aria-label="English" aria-pressed="false">EN</button>
        <button class="language-button" type="button" data-language="es" aria-label="Español" aria-pressed="false">ES</button>
      </div>
      <button class="theme-toggle" id="theme-toggle" type="button" data-i18n-aria-label="enableDarkMode">🌙</button>
    </div>

    <header class="hero">
      <p class="eyebrow" data-i18n="eyebrow"></p>
      <h1 data-i18n="heading"></h1>
      <p class="intro" data-i18n="intro"></p>
    </header>

    <section class="tool-card" data-i18n-aria-label="calculatorAriaLabel">
      <form id="roi-form" novalidate>
        <fieldset>
          <legend><span class="section-number">1</span><span data-i18n="baseData"></span></legend>
          <div class="form-grid">
            <div class="field"><label for="ral" data-i18n="currentSalary"></label><div class="input-wrapper"><input id="ral" name="ral" type="number" min="0" step="100" value="35000" required inputmode="decimal" aria-describedby="ral-error"><span class="suffix" data-i18n="euroSuffix"></span></div><span id="ral-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="produttivitaAnnua" data-i18n="annualProductivity"></label><div class="input-wrapper"><input id="produttivitaAnnua" name="produttivitaAnnua" type="number" min="0" step="100" value="33000" inputmode="decimal" aria-describedby="produttivitaAnnua-error"><span class="suffix" data-i18n="euroSuffix"></span></div><span id="produttivitaAnnua-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="percentualeFee" data-i18n="recruitmentFee"></label><div class="input-wrapper"><input id="percentualeFee" name="percentualeFee" type="number" min="0" max="100" step="0.1" value="15" inputmode="decimal" aria-describedby="percentualeFee-error"><span class="suffix">%</span></div><span id="percentualeFee-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="percentualePremio" data-i18n="changePremium"></label><div class="input-wrapper"><input id="percentualePremio" name="percentualePremio" type="number" min="0" max="100" step="0.1" value="20" inputmode="decimal" aria-describedby="percentualePremio-error"><span class="suffix">%</span></div><span id="percentualePremio-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="giorniTimeToHire" data-i18n="timeToHire"></label><div class="input-wrapper"><input id="giorniTimeToHire" name="giorniTimeToHire" type="number" min="0" step="1" value="45" inputmode="numeric" aria-describedby="giorniTimeToHire-error"><span class="suffix" data-i18n="daysSuffix"></span></div><span id="giorniTimeToHire-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="giorniLavorativiAnnui" data-i18n="annualWorkingDays"></label><div class="input-wrapper"><input id="giorniLavorativiAnnui" name="giorniLavorativiAnnui" type="number" min="1" step="1" value="250" inputmode="numeric" aria-describedby="giorniLavorativiAnnui-error"><span class="suffix" data-i18n="daysSuffix"></span></div><span id="giorniLavorativiAnnui-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="numeroSelezioni" data-i18n="numberOfHires"></label><div class="input-wrapper"><input id="numeroSelezioni" name="numeroSelezioni" type="number" min="1" step="1" value="10" inputmode="numeric" aria-describedby="numeroSelezioni-error"><span class="suffix">#</span></div><span id="numeroSelezioni-error" class="error-message" aria-live="polite"></span></div>
          </div>
        </fieldset>

        <fieldset>
          <legend><span class="section-number">3</span><span data-i18n="linkedinScenario"></span></legend>
          <div class="form-grid">
            <div class="field"><label for="riduzioneTimeToHireLinkedIn" data-i18n="linkedinTimeReduction"></label><div class="input-wrapper"><input id="riduzioneTimeToHireLinkedIn" name="riduzioneTimeToHireLinkedIn" type="number" min="0" max="100" step="0.1" value="30" inputmode="decimal" aria-describedby="riduzioneTimeToHireLinkedIn-error"><span class="suffix">%</span></div><span id="riduzioneTimeToHireLinkedIn-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="riduzionePremioLinkedIn" data-i18n="linkedinPremiumReduction"></label><p class="help-text" data-i18n="linkedinPremiumReductionHelp"></p><div class="input-wrapper"><input id="riduzionePremioLinkedIn" name="riduzionePremioLinkedIn" type="number" min="0" max="100" step="0.1" value="0" inputmode="decimal" aria-describedby="riduzionePremioLinkedIn-error"><span class="suffix">%</span></div><span id="riduzionePremioLinkedIn-error" class="error-message" aria-live="polite"></span></div>
            <div class="field"><label for="costoSoluzioneLinkedIn" data-i18n="linkedinSolutionCost"></label><p class="help-text" data-i18n="linkedinSolutionCostHelp"></p><div class="input-wrapper"><input id="costoSoluzioneLinkedIn" name="costoSoluzioneLinkedIn" type="number" min="0" step="100" value="15000" inputmode="decimal" aria-describedby="costoSoluzioneLinkedIn-error"><span class="suffix" data-i18n="euroSuffix"></span></div><span id="costoSoluzioneLinkedIn-error" class="error-message" aria-live="polite"></span></div>
          </div>
        </fieldset>
        <div class="actions"><button class="btn-secondary" type="button" id="reset-button" data-i18n="resetButton"></button></div>
      </form>
    </section>

    <section class="scenario-grid" aria-live="polite">
      <article class="scenario-card">
        <h2 class="section-title"><span class="section-number">2</span><span data-i18n="withoutLinkedInScenario"></span></h2>
        <div class="total-card"><p class="total-label" data-i18n="totalCostWithoutLinkedIn"></p><p class="total-value" id="costoTotaleSenzaLinkedIn">€ 0</p></div>
        <dl class="result-list">
          <div class="result-row"><dt data-i18n="dailyProductivity"></dt><dd id="produttivitaGiornaliera">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="timeToHireCost"></dt><dd id="costoTimeToHire">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="changePremium"></dt><dd id="premioCambio">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="estimatedNewSalary"></dt><dd id="nuovaRalStimata">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="recruitmentFee"></dt><dd id="feeSelezione">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="singleHireCost"></dt><dd id="costoSingolaSelezioneSenzaLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="numberOfHires"></dt><dd id="numeroSelezioniResult">0</dd></div>
        </dl>
        <div class="formula-box"><h3 data-i18n="calculationSummary"></h3><pre id="formulaSenzaLinkedIn"></pre></div>
      </article>

      <article class="scenario-card">
        <h2 class="section-title"><span class="section-number">3</span><span data-i18n="linkedinScenario"></span></h2>
        <div class="total-card"><p class="total-label" data-i18n="totalCostWithLinkedIn"></p><p class="total-value" id="costoTotaleConLinkedIn">€ 0</p></div>
        <p class="note" data-i18n="linkedinFeeNote"></p>
        <dl class="result-list">
          <div class="result-row"><dt data-i18n="initialTimeToHire"></dt><dd id="timeToHireIniziale">0</dd></div>
          <div class="result-row"><dt data-i18n="linkedinReduction"></dt><dd id="riduzioneTimeToHireLinkedInResult">0%</dd></div>
          <div class="result-row"><dt data-i18n="estimatedLinkedInTimeToHire"></dt><dd id="giorniTimeToHireLinkedIn">0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="timeToHireCost"></dt><dd id="costoTimeToHireLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="initialChangePremium"></dt><dd id="premioCambioInizialeLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="linkedinPremiumReduction"></dt><dd id="riduzionePremioLinkedInResult">0%</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="changePremiumLinkedIn"></dt><dd id="premioCambioLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="estimatedNewSalaryLinkedIn"></dt><dd id="nuovaRalStimataLinkedIn">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="linkedinRecruitmentFee"></dt><dd id="feeSelezioneLinkedIn">€ 0</dd></div>
          <div class="result-row is-emphasis"><dt data-i18n="singleHireCostLinkedIn"></dt><dd id="costoSingolaSelezioneConLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="operationalCostWithLinkedIn"></dt><dd id="costoOperativoTotaleConLinkedIn">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="linkedinSolutionCost"></dt><dd id="costoSoluzioneLinkedInResult">€ 0</dd></div>
          <div class="result-row"><dt data-i18n="averageCostPerHireWithLinkedIn"></dt><dd id="costoMedioPerSelezioneConLinkedIn">€ 0</dd></div>
        </dl>
        <div class="formula-box"><h3 data-i18n="calculationSummary"></h3><pre id="formulaConLinkedIn"></pre></div>
      </article>
    </section>

    <section class="comparison-card" aria-live="polite">
      <h2 class="section-title"><span class="section-number">4</span><span data-i18n="economicComparison"></span></h2>
      <div class="highlight-grid">
        <div class="metric-card" id="netSavingCard"><span data-i18n="netSaving"></span><strong id="risparmioNetto">€ 0</strong><p class="status-text" id="netSavingMessage"></p></div>
        <div class="metric-card" id="breakEvenCard"><span data-i18n="breakEven"></span><strong id="breakEvenSelezioni">0</strong><p class="status-text" id="breakEvenMessage"></p></div>
        <div class="metric-card" id="roiCard"><span data-i18n="roi"></span><strong id="roiLinkedIn">0,0%</strong><p class="status-text" id="roiMessage"></p></div>
      </div>
      <dl class="result-list">
        <div class="result-row"><dt data-i18n="totalCostWithoutLinkedIn"></dt><dd id="comparisonCostWithout">€ 0</dd></div>
        <div class="result-row"><dt data-i18n="totalCostWithLinkedIn"></dt><dd id="comparisonCostWith">€ 0</dd></div>
        <div class="result-row"><dt data-i18n="savingPerHire"></dt><dd id="risparmioPerSelezione">€ 0</dd></div>
        <div class="result-row"><dt data-i18n="totalOperationalSaving"></dt><dd id="risparmioOperativoTotale">€ 0</dd></div>
        <div class="result-row is-emphasis"><dt data-i18n="netSavingPercentage"></dt><dd id="risparmioNettoPercentuale">0,0%</dd></div>
        <div class="result-row"><dt data-i18n="averageCostPerHireWithoutLinkedIn"></dt><dd id="costoMedioPerSelezioneSenzaLinkedIn">€ 0</dd></div>
        <div class="result-row"><dt data-i18n="averageCostPerHireWithLinkedIn"></dt><dd id="comparisonAverageWith">€ 0</dd></div>
      </dl>
      <div class="formula-box"><h3 data-i18n="calculationSummary"></h3><pre id="formulaConfronto"></pre></div>
    </section>
  </main>

  <script>
    const storageKeys = { language: 'replacementCalculatorLanguage', theme: 'replacementCalculatorTheme' };
    const languageSettings = { it: { htmlLang: 'it', locale: 'it-IT' }, en: { htmlLang: 'en', locale: 'en-IE' }, es: { htmlLang: 'es', locale: 'es-ES' } };
    const translations = {
