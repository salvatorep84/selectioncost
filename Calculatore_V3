    function setFieldError(id, message) { const node = document.getElementById(`${id}-error`); inputs[id].setAttribute('aria-invalid', message ? 'true' : 'false'); node.textContent = message; }

    function readAndValidateInputs() {
      const values = {}; const errors = {};
      inputIds.forEach((id) => { const raw = inputs[id].value.trim(); const value = Number(raw); values[id] = value; if (raw === '') { errors[id] = id === 'ral' ? translate('salaryRequired') : id === 'numeroSelezioni' ? translate('numberOfHiresRequired') : translate('valueRequired'); return; } if (!Number.isFinite(value)) { errors[id] = translate('invalidNumber'); return; } if (value < 0) errors[id] = translate('negativeValue'); });
      ['percentualeFee','percentualePremio','riduzioneTimeToHireLinkedIn','riduzionePremioLinkedIn'].forEach((id) => { if (!errors[id] && values[id] > 100) errors[id] = translate('percentageAbove100'); });
      ['giorniTimeToHire','giorniLavorativiAnnui'].forEach((id) => { if (!errors[id] && !Number.isInteger(values[id])) errors[id] = translate('integerDays'); });
      if (!errors.giorniLavorativiAnnui && values.giorniLavorativiAnnui <= 0) errors.giorniLavorativiAnnui = translate('workingDaysAboveZero');
      if (!errors.numeroSelezioni && !Number.isInteger(values.numeroSelezioni)) errors.numeroSelezioni = translate('numberOfHiresInteger');
      if (!errors.numeroSelezioni && values.numeroSelezioni < 1) errors.numeroSelezioni = translate('numberOfHiresMinimum');
      inputIds.forEach((id) => setFieldError(id, errors[id] || ''));
      return { values, isValid: Object.keys(errors).length === 0 };
    }

    function calculateBaseScenario(values) {
      const premioCambio = values.ral * (values.percentualePremio / 100);
      const nuovaRalStimata = values.ral + premioCambio;
      const feeSelezione = nuovaRalStimata * (values.percentualeFee / 100);
      const produttivitaGiornaliera = values.produttivitaAnnua / values.giorniLavorativiAnnui;
      const costoTimeToHire = produttivitaGiornaliera * values.giorniTimeToHire;
      const costoSingolaSelezioneSenzaLinkedIn = feeSelezione + premioCambio + costoTimeToHire;
      const costoTotaleSenzaLinkedIn = costoSingolaSelezioneSenzaLinkedIn * values.numeroSelezioni;
      const costoMedioPerSelezioneSenzaLinkedIn = costoTotaleSenzaLinkedIn / values.numeroSelezioni;
      return { premioCambio, nuovaRalStimata, feeSelezione, produttivitaGiornaliera, costoTimeToHire, costoSingolaSelezioneSenzaLinkedIn, costoTotaleSenzaLinkedIn, costoMedioPerSelezioneSenzaLinkedIn };
    }

    function calculateLinkedInScenario(values, base) {
      const giorniTimeToHireLinkedIn = values.giorniTimeToHire * (1 - values.riduzioneTimeToHireLinkedIn / 100);
      const costoTimeToHireLinkedIn = base.produttivitaGiornaliera * giorniTimeToHireLinkedIn;
      const feeSelezioneLinkedIn = 0;
      const premioCambioLinkedIn = base.premioCambio * (1 - values.riduzionePremioLinkedIn / 100);
      const nuovaRalStimataLinkedIn = values.ral + premioCambioLinkedIn;
      const costoSingolaSelezioneConLinkedIn = feeSelezioneLinkedIn + premioCambioLinkedIn + costoTimeToHireLinkedIn;
      const costoOperativoTotaleConLinkedIn = costoSingolaSelezioneConLinkedIn * values.numeroSelezioni;
      const costoTotaleConLinkedIn = costoOperativoTotaleConLinkedIn + values.costoSoluzioneLinkedIn;
      const costoMedioPerSelezioneConLinkedIn = costoTotaleConLinkedIn / values.numeroSelezioni;
      return { giorniTimeToHireLinkedIn, costoTimeToHireLinkedIn, feeSelezioneLinkedIn, premioCambioLinkedIn, nuovaRalStimataLinkedIn, costoSingolaSelezioneConLinkedIn, costoOperativoTotaleConLinkedIn, costoTotaleConLinkedIn, costoMedioPerSelezioneConLinkedIn };
    }

    function calculateBreakEven(solutionCost, savingPerHire, numberOfHires) {
      if (solutionCost === 0) return { breakEvenHires: 0, reached: true, unavailable: false, remainingHires: 0 };
      if (savingPerHire <= 0) return { breakEvenHires: null, reached: false, unavailable: true, remainingHires: null };
      const breakEvenHires = Math.max(0, Math.ceil(solutionCost / savingPerHire));
      const reached = numberOfHires >= breakEvenHires;
      return { breakEvenHires, reached, unavailable: false, remainingHires: reached ? 0 : breakEvenHires - numberOfHires };
    }

    function calculateRoi(netSaving, solutionCost) {
      if (solutionCost === 0) return { roi: null, applicable: false, benefitPerEuro: null };
      return { roi: (netSaving / solutionCost) * 100, applicable: true, benefitPerEuro: netSaving / solutionCost };
    }

    function calculateComparison(values, base, linkedIn) {
      const risparmioPerSelezione = base.costoSingolaSelezioneSenzaLinkedIn - linkedIn.costoSingolaSelezioneConLinkedIn;
      const risparmioOperativoTotale = risparmioPerSelezione * values.numeroSelezioni;
      const risparmioNetto = base.costoTotaleSenzaLinkedIn - linkedIn.costoTotaleConLinkedIn;
      const risparmioNettoPercentuale = base.costoTotaleSenzaLinkedIn > 0 ? (risparmioNetto / base.costoTotaleSenzaLinkedIn) * 100 : 0;
      const breakEven = calculateBreakEven(values.costoSoluzioneLinkedIn, risparmioPerSelezione, values.numeroSelezioni);
      const roi = calculateRoi(risparmioNetto, values.costoSoluzioneLinkedIn);
      return { risparmioPerSelezione, risparmioOperativoTotale, risparmioNetto, risparmioNettoPercentuale, breakEven, roi };
    }

